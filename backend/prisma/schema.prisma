// STICK Backend — Prisma Schema (MySQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Core User ───────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  email            String?   @unique
  passwordHash     String?
  name             String
  isGuest          Boolean   @default(false)
  bio              String?   @db.Text
  nativeLanguage   String?
  avatarUrl        String?   @db.MediumText
  firebaseUid      String?   @unique
  firebaseProvider String?
  role             String    @default("user")  // "user" | "admin"
  status           String    @default("active") // "active" | "banned"
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Cached EXP / streak fields (updated via awardXp + streak logic)
  totalXp          Int       @default(0)
  currentStreak    Int       @default(0)
  bestStreak        Int       @default(0)
  lastActiveDate   DateTime? @db.Date

  // Premium subscription
  isPremium        Boolean   @default(false)
  premiumSince     DateTime?
  premiumUntil     DateTime?  // null = lifetime while isPremium=true

  sessions         Session[]
  onboarding       OnboardingState?
  journals         Journal[]
  settings         UserSettings?
  reminders        Reminder[]
  notifications    Notification[]
  userAchievements UserAchievement[]
  savedPhrases     SavedPhrase[]
  vocabItems       VocabNotebookItem[]
  learningSessions LearningSession[]
  progressDaily    ProgressDaily[]
  errorPatterns    LearnerErrorPattern[]
  lexiconItems     LearnerLexicon[]
  xpLogs           UserXpLog[]
  streakFreezes    StreakFreeze[]
  lessonAttempts   LessonAttempt[]
  exerciseAttempts ExerciseAttempt[]
  lessonProgress   UserLessonProgress[]
  pathProgress     UserPathProgress[]
}

// ─── Auth ────────────────────────────────────────────
model Session {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Onboarding ──────────────────────────────────────
model OnboardingState {
  id        String   @id @default(uuid())
  userId    String   @unique
  step      Int      @default(0)
  level     String?
  schedule  String?
  goal      String?
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Journals ────────────────────────────────────────
model Journal {
  id        String    @id @default(uuid())
  userId    String
  title     String
  content   String    @db.Text
  status    String    @default("draft")
  score     Int?
  feedback  String?   @db.Text
  language  String    @default("en")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ─── User Settings ───────────────────────────────────
model UserSettings {
  id               String   @id @default(uuid())
  userId           String   @unique
  theme            String   @default("system") // "light", "dark", "system"
  language         String   @default("en")
  notificationsOn  Boolean  @default(true)
  soundOn          Boolean  @default(true)
  dailyGoalMinutes Int      @default(15)
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Reminders ───────────────────────────────────────
model Reminder {
  id        String   @id @default(uuid())
  userId    String
  time      String   // "08:00", "20:30"
  days      String   // "mon,tue,wed,thu,fri"
  enabled   Boolean  @default(true)
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Notifications ───────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "achievement", "streak", "feedback", "system"
  title     String
  body      String   @db.Text
  read      Boolean  @default(false)
  data      String?  @db.Text // JSON metadata
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
}

// ─── Achievements ────────────────────────────────────
model AchievementDefinition {
  id          String   @id @default(uuid())
  key         String   @unique
  title       String
  description String   @db.Text
  icon        String
  category    String   // "journal", "streak", "vocabulary", "speaking"
  threshold   Int      @default(1)
  xpReward    Int      @default(0)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  progress      Int      @default(0)

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   AchievementDefinition @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}

// ─── Saved Phrases ───────────────────────────────────
model SavedPhrase {
  id        String   @id @default(uuid())
  userId    String
  phrase    String
  meaning   String?  @db.Text
  example   String?  @db.Text
  category  String   @default("general")
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ─── Vocab Notebook ──────────────────────────────────
model VocabNotebookItem {
  id             String    @id @default(uuid())
  userId         String
  word           String
  meaning        String?   @db.Text
  example        String?   @db.Text
  mastery        String    @default("new") // "new", "learning", "mastered"
  tags           String?   // comma-separated
  notes          String?   @db.Text
  sourceJournalId String?  // which journal produced this item
  fromAI         Boolean   @default(false) // imported from AI feedback
  nextReviewAt   DateTime?
  easeFactor     Float     @default(2.5)
  reviewInterval Int       @default(0)   // days until next review
  reviewCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, mastery, updatedAt(sort: Desc)])
  @@index([userId, nextReviewAt])
}

// ─── Learning Sessions (History) ─────────────────────
model LearningSession {
  id          String   @id @default(uuid())
  userId      String
  type        String   // "journal", "speaking", "grammar", "listening", "reading"
  title       String
  summary     String?  @db.Text
  score       Int?
  duration    Int?     // in seconds
  metadata    String?  @db.Text // JSON extra data
  completedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt(sort: Desc)])
}

// ─── Progress Daily ──────────────────────────────────
model ProgressDaily {
  id            String   @id @default(uuid())
  userId        String
  day           DateTime @db.Date
  journalsCount Int      @default(0)
  wordsLearned  Int      @default(0)
  minutesSpent  Int      @default(0)
  xpEarned      Int      @default(0)

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId, day(sort: Desc)])
}

// ─── Lessons (Library content) ───────────────────────
model LearningPath {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  titleVi     String?
  description String   @db.Text
  coverImage  String?  @db.Text
  level       String   @default("beginner")
  isPremium   Boolean  @default(false)
  orderIndex  Int      @default(0)
  published   Boolean  @default(false)
  units       Unit[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Unit {
  id             String       @id @default(uuid())
  learningPathId String
  learningPath   LearningPath @relation(fields: [learningPathId], references: [id], onDelete: Cascade)
  slug           String
  title          String
  titleVi        String?
  description    String?      @db.Text
  coverImage     String?      @db.Text
  orderIndex     Int          @default(0)
  isPremium      Boolean      @default(false)
  published      Boolean      @default(false)
  modules        Module[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([learningPathId, slug])
  @@index([learningPathId, orderIndex])
}

model Module {
  id          String   @id @default(uuid())
  unitId      String
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  title       String
  titleVi     String?
  orderIndex  Int      @default(0)
  published   Boolean  @default(false)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([unitId, orderIndex])
}

model Lesson {
  id          String   @id @default(uuid())
  moduleId    String?
  module      Module?  @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  title       String
  titleVi     String?
  description String   @db.Text
  category    String   @default("grammar")
  level       String   @default("beginner")
  content     String   @db.LongText
  duration    Int      @default(5)
  orderIndex  Int      @default(0)
  published   Boolean  @default(true)
  xpReward    Int      @default(15)
  isPremium   Boolean  @default(false)
  tags        String?  @db.Text
  aiGenerated Boolean  @default(false)
  status      String   @default("published") // "draft" | "review" | "published" | "archived"
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  attempts    LessonAttempt[]

  @@index([category, level])
  @@index([moduleId, orderIndex])
  @@index([status])
}

model LessonAttempt {
  id            String   @id @default(uuid())
  userId        String
  lessonId      String
  score         Int      @default(0)
  starRating    Int      @default(0)
  xpEarned      Int      @default(0)
  comboMax      Int      @default(0)
  duration      Int      @default(0)
  answers       String   @db.LongText
  isReview      Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([userId, lessonId])
  @@index([userId, createdAt(sort: Desc)])
}

model ExerciseAttempt {
  id            String   @id @default(uuid())
  userId        String
  lessonId      String
  exerciseIndex Int
  exerciseType  String
  answer        String   @db.Text
  correct       Boolean  @default(false)
  points        Int      @default(0)
  timeSpent     Int      @default(0)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, exerciseType])
  @@index([userId, lessonId])
}

model UserLessonProgress {
  id               String    @id @default(uuid())
  userId           String
  lessonId         String
  bestScore        Int       @default(0)
  starRating       Int       @default(0)
  totalAttempts    Int       @default(0)
  totalXpEarned    Int       @default(0)
  firstCompletedAt DateTime?
  lastAttemptAt    DateTime?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}

model UserPathProgress {
  id               String    @id @default(uuid())
  userId           String
  learningPathId   String
  unitsCompleted   Int       @default(0)
  totalUnits       Int       @default(0)
  currentUnitId    String?
  currentLessonId  String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, learningPathId])
}

// ─── Daily Prompts (Admin-managed) ───────────────────
model DailyPrompt {
  id            String   @id @default(uuid())
  publishDate   DateTime @db.Date
  status        String   @default("draft")     // "draft" | "scheduled" | "published"
  internalTitle String
  promptVi      String   @db.Text
  promptEn      String   @db.Text
  followUp      String?  @db.Text
  level         String   @default("basic")     // "basic" | "intermediate" | "advanced"
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([publishDate])
  @@index([status, publishDate])
}

// ─── Learner Error Patterns ─────────────────────────
model LearnerErrorPattern {
  id           String   @id @default(uuid())
  userId       String
  errorType    String   // "past_tense" | "article_usage" | "preposition" | "word_choice" | "capitalization" | "noun_number" | "subject_verb_agreement" | "collocation" | "tense_usage" | "other"
  count        Int      @default(1)
  lastSeenAt   DateTime @default(now())
  exampleError String?  @db.Text
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, errorType])
  @@index([userId, count(sort: Desc)])
}

// ─── Learner Lexicon (per-user expression knowledge memory) ──────────
model LearnerLexicon {
  id                    String    @id @default(uuid())
  userId                String
  expression            String    @db.VarChar(255) // canonical lowercase form
  expressionType        String    @default("word") // word | phrase | collocation | chunk
  aiSuggestedCount      Int       @default(0)
  userSavedCount        Int       @default(0)
  userUsedCount         Int       @default(0)
  correctUseCount       Int       @default(0)
  incorrectUseCount     Int       @default(0)
  correctUseSessions    Int       @default(0) // distinct sessions with correct use
  reviewSuccessCount    Int       @default(0)
  reviewFailCount       Int       @default(0)
  knowledgeState        String    @default("unseen") // unseen | noticed | learning | activating | stable | mastered
  relatedNotebookItemId String?
  lastJournalId         String?
  firstSeenAt           DateTime  @default(now())
  lastSuggestedAt       DateTime?
  lastUsedAt            DateTime?
  lastReviewedAt        DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, expression])
  @@index([userId, knowledgeState])
  @@index([userId, correctUseCount(sort: Desc)])
}

// ─── AI Logs ─────────────────────────────────────────
model AILog {
  id           String   @id @default(uuid())
  userId       String
  journalId    String?
  inputText    String   @db.Text
  outputText   String?  @db.Text
  model        String   @default("llama-3.3-70b-versatile")
  statusCode   Int      @default(200)
  latencyMs    Int      @default(0)
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([statusCode])
}

// ─── App Config ──────────────────────────────────────
model AppConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.LongText
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ─── Streak Freeze ──────────────────────────────────
model StreakFreeze {
  id          String    @id @default(uuid())
  userId      String
  source      String    @default("admin")  // "admin" | "achievement" | "reward"
  note        String?   @db.Text
  grantedBy   String?   // null = system/achievement; admin userId if manual
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime?
  usedAt      DateTime?
  usedForDate DateTime? @db.Date

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, usedAt])
}

// ─── XP Log ──────────────────────────────────────────
model UserXpLog {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  source      String   // "journal", "feedback", "vocab", "phrase", "session", "achievement"
  description String?
  journalId   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}
